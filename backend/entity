package com.example.knowledgegap.entity;

import jakarta.persistence.*;

@Entity
@Table(name = "recommendations")
public class Recommendation {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private Long employeeId;

    private String missingSkill;

    private String recommendedCourse;

    private String description;

    public Recommendation() {
    }

    public Recommendation(Long employeeId, String missingSkill, String recommendedCourse, String description) {
        this.employeeId = employeeId;
        this.missingSkill = missingSkill;
        this.recommendedCourse = recommendedCourse;
        this.description = description;
    }

    public Long getId() {
        return id;
    }

    public Long getEmployeeId() {
        return employeeId;
    }

    public void setEmployeeId(Long employeeId) {
        this.employeeId = employeeId;
    }

    public String getMissingSkill() {
        return missingSkill;
    }

    public void setMissingSkill(String missingSkill) {
        this.missingSkill = missingSkill;
    }

    public String getRecommendedCourse() {
        return recommendedCourse;
    }

    public void setRecommendedCourse(String recommendedCourse) {
        this.recommendedCourse = recommendedCourse;
    }

    public String getDescription() {
        return description;
    }

    public void setDescription(String description) {
        this.description = description;
    }
}
